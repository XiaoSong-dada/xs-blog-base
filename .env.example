# ---------- Shared ----------
TZ=Asia/Shanghai

# ---------- PostgreSQL ----------
POSTGRES_DB=icu_xiaosong_blog
POSTGRES_USER=icu_xiaosong_blog_user
POSTGRES_PASSWORD=change_me
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_PUBLISH_PORT=28888
DATABASE_URL=

# ---------- Redis ----------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PUBLISH_PORT=27888
REDIS_DB=0
REDIS_URL=
REDIS_PASSWORD=change_me_redis
REDIS_PREFIX=blog

# ---------- Auth ----------
SECRET_KEY=change_me_secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=300

# ---------- API ----------
# 生产环境如果改为前端直连后端，请把前端站点域名加入 ALLOWED_ORIGINS。
ALLOWED_ORIGINS=["http://localhost:5173","http://localhost"]
FILE_STORAGE_PATH=./storage
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800
DB_POOL_PRE_PING=true
API_PUBLISH_PORT=26888
PG_DATA_VOLUME_NAME=xs-blog-base-pg-data-dev
REDIS_DATA_VOLUME_NAME=xs-blog-base-redis-data-dev

# ---------- Email ----------
EMAIL_HOST=smtp.qq.com
EMAIL_PORT=465
EMAIL_CODE=change_me_mail_auth_code
EMAIL_SENDER=example@qq.com
EMAIL_FROM_NAME=xs-blog

# ---------- Web Build / Dev ----------
# 开发环境默认直连，生产环境默认走同源 /api 代理。
# 如需覆盖默认行为，可显式设置 VITE_API_REQUEST_MODE=direct 或 proxy。
VITE_BACKEND_API_URL=
VITE_STATIC_URL=
VITE_VDITOR_CDN=/vditor
VITE_SITE_NAME=xs-blog
VITE_SITE_ICP=
VITE_SITE_ICP_LINK=
VITE_GITHUB_REPO=xs-blog
VITE_GITHUB_REPO_URL=https://github.com/your-name/xs-blog
VITE_BACKEND_BASE_URL=
VITE_BACKEND_STATIC=static
WEB_PUBLISH_PORT=25888
WEB_DEV_PUBLISH_PORT=25173
