# ---------- Shared ----------
TZ=Asia/Shanghai

# ---------- PostgreSQL ----------
POSTGRES_DB=icu_xiaosong_blog
POSTGRES_USER=icu_xiaosong_blog_user
POSTGRES_PASSWORD=change_me
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URL=postgresql://icu_xiaosong_blog_user:change_me@db:5432/icu_xiaosong_blog

# ---------- Redis ----------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_URL=redis://:change_me_redis@redis:6379/0
REDIS_PASSWORD=change_me_redis
REDIS_PREFIX=blog

# ---------- Auth ----------
SECRET_KEY=change_me_secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=300

# ---------- API ----------
ALLOWED_ORIGINS=["http://localhost:5173","http://localhost"]
FILE_STORAGE_PATH=./storage
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800
DB_POOL_PRE_PING=true

# ---------- Email ----------
EMAIL_HOST=smtp.qq.com
EMAIL_PORT=465
EMAIL_CODE=change_me_mail_auth_code
EMAIL_SENDER=example@qq.com
EMAIL_FROM_NAME=xs-blog

# ---------- Web Build / Dev ----------
VITE_BACKEND_API_URL=http://localhost:8000
VITE_STATIC_URL=/static/
VITE_VDITOR_CDN=/vditor
VITE_SITE_NAME=xs-blog
VITE_SITE_ICP=
VITE_SITE_ICP_LINK=
VITE_GITHUB_REPO=xs-blog
VITE_GITHUB_REPO_URL=https://github.com/your-name/xs-blog
VITE_BACKEND_BASE_URL=
VITE_BACKEND_STATIC=static
